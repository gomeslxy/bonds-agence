# Supabase (Required for Frontend & Backend)
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key

# Supabase Service Role (Required for Server-side Admin Operations)
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# Admin Authentication
ADMIN_PASSWORD=your-secure-admin-password

# Application URL
NEXT_PUBLIC_SITE_URL=http://localhost:3000

# Google Analytics
NEXT_PUBLIC_GA_ID=G-XXXXXXXXXX

# Upstash Redis (Required for Rate Limiting)
UPSTASH_REDIS_REST_URL=https://your-redis.upstash.io
UPSTASH_REDIS_REST_TOKEN=your-token

# Stripe (Required for Checkout & Webhooks)
# Get these from dashboard.stripe.com/apikeys
STRIPE_SECRET_KEY=sk_test_...
STRIPE_WEBHOOK_SECRET=whsec_...

# Resend (Optional - for emails)
# Get this from resend.com
RESEND_API_KEY=re_...
RESEND_FROM_EMAIL=onboarding@resend.dev

# Admin Authentication
ADMIN_PASSWORD=your-secure-admin-password
ADMIN_EMAIL=admin@example.com
NEXT_PUBLIC_ADMIN_EMAIL=admin@example.com
ADMIN_JWT_SECRET=generate-a-long-random-string-here
